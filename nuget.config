<?xml version="1.0" encoding="utf-8"?>
<!--
  CS2MenuManager is consumed from the Forgejo package registry
  (git.miksen.me/mikkel/CS2MenuManager) instead of nuget.org. packageSourceMapping
  pins ONLY that package to the "forgejo" source; everything else stays on nuget.org.

  The forgejo source needs auth. Credentials are NOT committed here; provide them
  via the environment variable (CI does this from secrets):

    NuGetPackageSourceCredentials_forgejo="Username=USER;Password=FORGEJO_TOKEN"

  For local dev, export the same var, or register the source with credentials via
  the "dotnet nuget update source forgejo" command using your Forgejo username and
  a personal access token.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="forgejo" value="https://git.miksen.me/api/packages/mikkel/nuget/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="forgejo">
      <package pattern="CS2MenuManager" />
    </packageSource>
  </packageSourceMapping>
</configuration>
